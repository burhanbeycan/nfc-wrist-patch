{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://burhanbeycan.github.io/nfc-wrist-patch/schema/fabric-reading.schema.json",
  "title": "Fabric NTAG213 Heartbeat Reading",
  "type": "object",
  "required": ["schema", "patchId", "measuredAt", "readMode", "nfc", "vitals", "signal"],
  "properties": {
    "schema": { "const": "fabric-ntag213-heart.v1" },
    "patchId": { "type": "string", "minLength": 1, "maxLength": 32, "pattern": "^[A-Za-z0-9._-]+$" },
    "patchName": { "type": "string", "maxLength": 120 },
    "subjectAlias": { "type": "string", "maxLength": 120 },
    "measuredAt": { "type": "string", "format": "date-time" },
    "readMode": { "enum": ["static-json", "compact-url-snapshot", "patch-id-url", "encoded-json-url", "backend-api", "dynamic-nfc"] },
    "nfc": {
      "type": "object",
      "required": ["chip", "ndef", "tagMemoryBytes"],
      "properties": {
        "chip": { "type": "string" },
        "uid": { "type": "string" },
        "ndef": { "type": "string" },
        "tagMemoryBytes": { "type": "number", "minimum": 0, "maximum": 4096 }
      },
      "additionalProperties": true
    },
    "vitals": {
      "type": "object",
      "required": ["heartRateBpm", "confidence"],
      "properties": {
        "heartRateBpm": { "type": "number", "minimum": 0, "maximum": 260 },
        "spo2Percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "skinTempC": { "type": "number", "minimum": 0, "maximum": 60 },
        "hrvRmssdMs": { "type": "number", "minimum": 0, "maximum": 250 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "signal": {
      "type": "object",
      "properties": {
        "qualityPercent": { "type": "number", "minimum": 0, "maximum": 100 },
        "motionArtifactPercent": { "type": "number", "minimum": 0, "maximum": 100 },
        "contact": { "type": "string" },
        "batteryPercent": { "type": "number", "minimum": 0, "maximum": 100 },
        "sensorMode": { "type": "string" }
      },
      "additionalProperties": true
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["t", "bpm"],
        "properties": {
          "t": { "type": "number" },
          "bpm": { "type": "number", "minimum": 0, "maximum": 260 }
        }
      }
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "level": { "enum": ["ok", "info", "warn", "danger"] },
          "title": { "type": "string" },
          "detail": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
